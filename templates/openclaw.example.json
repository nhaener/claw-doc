{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_AUTH_TOKEN}"
    }
  },
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "${WORKSPACE_ROOT}",
      "model": {
        "primary": "openai/gpt-5.4"
      }
    },
    "list": [
      {
        "id": "claw-doc",
        "name": "claw-doc",
        "default": true
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "disabled",
      "accounts": {
        "clawdoc": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "pairing",
          "groupPolicy": "disabled"
        }
      },
      "defaultAccount": "clawdoc"
    }
  },
  "plugins": {
    "allow": ["telegram", "openai"],
    "entries": {
      "telegram": {
        "enabled": true
      },
      "openai": {
        "enabled": true
      }
    }
  }
}
